{
  "name": "stackfox",
  "private": true,
  "workspaces": [
    "apps/*",
    "packages/*"
  ],
  "packageManager": "npm@11.9.0",
  "engines": {
    "node": "24.14.0"
  },
  "scripts": {
    "dev": "node ./scripts/dev.mjs",
    "dev:dashboard": "npm run dev --workspace @stackfox/dashboard",
    "dev:api": "npm run dev --workspace @stackfox/api",
    "build": "npm run build --workspaces --if-present",
    "build:dashboard": "npm run build --workspace @stackfox/dashboard",
    "build:api": "npm run prisma:generate --workspace @stackfox/api",
    "lint": "npm run lint --workspaces --if-present",
    "predeploy:api": "npm run prisma:deploy --workspace @stackfox/api",
    "start:dashboard": "npm run start --workspace @stackfox/dashboard",
    "start:api": "npm run start --workspace @stackfox/api",
    "test": "npm run test --workspaces --if-present",
    "typecheck": "npm run typecheck --workspaces --if-present",
    "prisma:generate": "npm run prisma:generate --workspace @stackfox/api"
  }
}
