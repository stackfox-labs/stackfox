{
  "name": "stackfox",
  "private": true,
  "workspaces": [
    "apps/*",
    "packages/*"
  ],
  "scripts": {
    "dev": "node ./scripts/dev.mjs",
    "dev:dashboard": "npm run dev --workspace @stackfox/dashboard",
    "dev:api": "npm run dev --workspace @stackfox/api",
    "build": "npm run build --workspaces --if-present",
    "lint": "npm run lint --workspaces --if-present",
    "test": "npm run test --workspaces --if-present",
    "typecheck": "npm run typecheck --workspaces --if-present",
    "prisma:generate": "npm run prisma:generate --workspace @stackfox/api"
  }
}