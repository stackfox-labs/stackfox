generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model Project {
  id            String              @id
  name          String
  apiKey        String              @unique @map("api_key")
  createdAt     DateTime            @default(now()) @map("created_at")
  records       RecordEntry[]
  events        Event[]
  memberships   ProjectMembership[]
  activityLogs  ActivityLog[]

  @@map("projects")
}

model ActivityLog {
  id        String   @id @default(uuid()) @db.Uuid
  projectId String   @map("project_id")
  action    String
  status    String   @default("success")
  message   String
  meta      Json?
  createdAt DateTime @default(now()) @map("created_at")
  project   Project  @relation(fields: [projectId], references: [id], onDelete: Cascade)

  @@index([projectId, createdAt(sort: Desc)])
  @@map("activity_logs")
}

model DashboardUser {
  id              String             @id @default(uuid()) @db.Uuid
  robloxUserId    String             @unique @map("roblox_user_id")
  username        String
  displayName     String             @map("display_name")
  avatarUrl       String?            @map("avatar_url")
  createdAt       DateTime           @default(now()) @map("created_at")
  updatedAt       DateTime           @updatedAt @map("updated_at")
  sessions        DashboardSession[]
  memberships     ProjectMembership[]

  @@map("dashboard_users")
}

model DashboardSession {
  id           String        @id @default(uuid()) @db.Uuid
  userId       String        @map("user_id") @db.Uuid
  accessToken  String        @map("access_token")
  refreshToken String?       @map("refresh_token")
  tokenType    String        @default("Bearer") @map("token_type")
  scope        String        @default("")
  expiresAt    DateTime?     @map("expires_at")
  createdAt    DateTime      @default(now()) @map("created_at")
  lastSeenAt   DateTime      @default(now()) @map("last_seen_at")
  user         DashboardUser @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@map("dashboard_sessions")
}

model OauthLoginState {
  id           String   @id @default(uuid()) @db.Uuid
  state        String   @unique
  codeVerifier String   @map("code_verifier")
  returnTo     String   @default("/dashboard") @map("return_to")
  expiresAt    DateTime @map("expires_at")
  createdAt    DateTime @default(now()) @map("created_at")

  @@map("oauth_login_states")
}

model ProjectMembership {
  id        String        @id @default(uuid()) @db.Uuid
  userId    String        @map("user_id") @db.Uuid
  projectId String        @map("project_id")
  role      String        @default("owner")
  createdAt DateTime      @default(now()) @map("created_at")
  user      DashboardUser @relation(fields: [userId], references: [id], onDelete: Cascade)
  project   Project       @relation(fields: [projectId], references: [id], onDelete: Cascade)

  @@unique([userId, projectId])
  @@map("project_memberships")
}

model RecordEntry {
  id         String   @id @default(uuid()) @db.Uuid
  projectId  String   @map("project_id")
  collection String
  recordKey  String   @map("record_key")
  dataJsonb  Json     @map("data_jsonb")
  createdAt  DateTime @default(now()) @map("created_at")
  updatedAt  DateTime @updatedAt @map("updated_at")
  project    Project  @relation(fields: [projectId], references: [id], onDelete: Cascade)

  @@unique([projectId, collection, recordKey])
  @@map("records")
}

model Event {
  id          String   @id @default(uuid()) @db.Uuid
  projectId   String   @map("project_id")
  eventName   String   @map("event_name")
  payloadJson Json     @map("payload_json")
  createdAt   DateTime @default(now()) @map("created_at")
  project     Project  @relation(fields: [projectId], references: [id], onDelete: Cascade)

  @@index([projectId, createdAt(sort: Desc)])
  @@index([projectId, eventName])
  @@map("events")
}
